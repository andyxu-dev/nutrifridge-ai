# NutriFridge AI — Backend Environment Variables
# Copy this file to .env and fill in your values.

# ── AI Nutrition Assistant ─────────────────────────────────────────────────
# Required for the AI Nutrition Assistant (/assistant/chat).
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ── Database ───────────────────────────────────────────────────────────────
# Default: SQLite (local file). Change for PostgreSQL in production.
# Example PostgreSQL: postgresql://user:password@localhost:5432/nutrifridge
# SQLALCHEMY_DATABASE_URL=sqlite:///./nutrifridge.db

# ── Server ─────────────────────────────────────────────────────────────────
# PORT=8000
